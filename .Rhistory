# Air pollution app
library(dplyr)
library(ggplot2)
library(readr)
library(shiny)
library(DT)
# Data prep
url <- 'https://ourworldindata.org/grapher/long-run-air-pollution.csv?v=1&csvType=full&useColumnShortNames=true'
air <- read_csv(url)
air %>% head
names(air) <- gsub('emissions__pollutant_','', names(air))
names(air) <- gsub('__sector_all_sectors','', names(air))
air <- air %>% mutate(total = nox + so2 + co + bc + nh3 + nmvoc)
air %>% head
###################################################################
###################################################################
# Define UI for application that draws a histogram
ui <- fluidPage(
titlePanel('The story of air'),
p('Here is a nice little tagline about my dashboard'),
helpText('this is helpText, a little more subtle maybe?'),
tabsetPanel(
tabPanel(h5('Time series'),
fluidRow(column(4, sliderInput(inputId = 'year',
label = 'Select years',
min = min(air$year),
max = max(air$year),
value = range(air$year))),
column(4, selectInput(inputId = 'entity',
label = 'Select countries',
multiple = TRUE,
choices = unique(air$entity),
selected = ''),
radioButtons(inputId = 'rank',
label = 'rank countries ...',
choices = c('Alphabetically',
'By total emissions'),
selected = 'Alphabetically')),
column(4, radioButtons(inputId = 'yvar',
label = 'Select variable',
choices = names(air)[-1:-3],
selected = 'total',
inline = TRUE))),
br(),
br(),
fluidRow(column(1),
column(10, plotOutput("airplot")),
column(1))
),
tabPanel(h5('Data viewer'),
fluidRow(column(12, DTOutput('dt1'))))
)
)
# Define server logic required to draw a histogram
server <- function(input, output) {
# We will pick up here -- REACTIVE VALUES that are remembered across server outputs
rv <- reactiveValues()
rv$air <- air
observe({
if(! is.null(input$entity)){
rv$air <- air %>% filter(entity %in% input$entity)
}else{rv$air <- air}
})
output$entity <- renderUI({
(countries <- air %>% pull(entity) %>% unique %>% sort)
# if inupt$rank is "Althabetical ...
# leave the country choices untoched
# if not (ranking by total emissions)
# rank them by emissions
})
output$airplot <- renderPlot({
print(input$entity)
if(input$entity %>% is.null){
# this is where ALL countries are shown
ggplot(rv$air,
aes_string(x='year',
y=input$yvar,
group = 'entity')
) +
geom_path() +
xlim(input$year)
}else{
# this is where only selected are shown
ggplot(rv$air,
# air %>% filter(entity %in% input$entity),
# aes(x=year, y=total, color=entity) # what we used to have
# aes(x=year, y=input$yvar, color=entity) # what you might think we should do
aes_string(x='year',
y=input$yvar,
color='entity')
) + # what we should actually do
geom_path() +
xlim(input$year)
}
})
output$dt1 <- renderDT({ rv$air })
}
# Run the application
shinyApp(ui = ui, server = server)
(countries <- air %>% pull(entity) %>% unique %>% sort)
air %>% head
air %>%
group_by(entity) %>%
summarize(total = sum(total)) %>%
arrange(dec(total)) %>%
pull(entity)
air %>%
group_by(entity) %>%
summarize(total = sum(total)) %>%
arrange(desc(total)) %>%
pull(entity)
runApp('Desktop/R_Scripts/ESCI 222/airdash')
runApp('Desktop/R_Scripts/ESCI 222/airdash')
runApp('Desktop/R_Scripts/ESCI 222/airdash')
