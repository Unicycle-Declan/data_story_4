# borrow from date
## modify Timestamp
### split Timestamp
splits <- str_split(Survey$Timestamp, " ")
### pad time and apply
Survey$`What time is it right now?` <-
str_pad(sapply(splits, '[[', 2),
width = 8, side = "left", pad = 0)
# clean frisbee ----
Survey$`Who can throw a frisbee farther: John Benson or Eric Ezell?` %>% unique()
## borrow from ping pong and hamilton
e <-
grepl("John", Survey$`Who can throw a frisbee farther: John Benson or Eric Ezell?`, ignore.case = TRUE) |
grepl("Benson", Survey$`Who can throw a frisbee farther: John Benson or Eric Ezell?`, ignore.case = TRUE)
Survey <-
Survey %>%
mutate(`Who can throw a frisbee farther: John Benson or Eric Ezell?` = e) %>%
mutate(`Who can throw a frisbee farther: John Benson or Eric Ezell?` =
gsub("TRUE", "John Benson",`Who can throw a frisbee farther: John Benson or Eric Ezell?`),
`Who can throw a frisbee farther: John Benson or Eric Ezell?` =
gsub("FALSE", "Eric Ezell",`Who can throw a frisbee farther: John Benson or Eric Ezell?`))
# final
# graph ----
survey <-
Survey %>%
rename(`25`=`What do you expect your annual income to be when you are 25?`,
`35`=`What do you expect your annual income to be when you are 35?`,
`55`=`What do you expect your annual income to be when you are 55?`) %>%
mutate(ID = 1:17) %>%
pivot_longer(cols = `25`:`55`,
names_to = "age",
values_to = "Expected Income")
ggplot(survey,
aes(x = age,
y = `Expected Income`,
group = ID
)
) +
geom_path() +
geom_point() +
labs(title = "Future Monitary Goals",
subtitle = "What do you expect your annual income to be when you are 25, 35, and 55?",
y = "Expected Income (USD)") +
scale_y_continuous(trans = "log",
breaks = c(5000000,25000000,1000000000,75000000000))
ggplot(survey,
aes(x = age,
y = `Expected Income`,
group = ID
)
) +
geom_path() +
geom_point() +
labs(title = "Future Monitary Goals",
subtitle = "What do you expect your annual income to be when you are 25, 35, and 55?",
y = "Expected Income (USD)") +
scale_y_continuous(trans = "log",
breaks = c(500000,25000000,1000000000,75000000000))
ggplot(survey,
aes(x = age,
y = (`Expected Income`/1000000),
group = ID
)
) +
geom_path() +
geom_point() +
labs(title = "Future Monitary Goals",
